{
  "name": "animated-icons-vue",
  "version": "0.2.2",
  "description": "402+ animated SVG icons for Vue 3, with hover and programmatic animations",
  "author": "AaronWangCong",
  "license": "MIT",
  "homepage": "https://animated-icons.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/AaronWangCong/animated-icons.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/AaronWangCong/animated-icons/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "icons",
    "animated",
    "svg",
    "animation",
    "components"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "require": "./dist/*.js",
      "types": "./dist/icons/*.vue.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
